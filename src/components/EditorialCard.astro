---
interface Props {
  label: string;
  title: string;
  description: string;
  image: string;
  alt: string;
  readTime?: string;
}

const {
  label,
  title,
  description,
  image,
  alt,
  readTime = "Read Protocol",
} = Astro.props;

import { slugify } from "./../utils";
---

<a class="group flex cursor-pointer flex-col gap-10 md:flex-row" href={`/shellbees/protocols/${slugify(label)}/`}>
  <div class="aspect-[4/3] shrink-0 overflow-hidden rounded-lg md:w-1/3">
    <img
      src={image}
      alt={alt}
      class="h-full w-full object-cover transition-transform group-hover:scale-105"
    />
  </div>
  <div class="flex flex-col justify-center border-l-4 border-secondary pl-8">
    <div class="mb-3 flex items-center gap-4">
      <span class="text-xs font-bold tracking-widest text-primary">{label}</span
      >
      {
        readTime && (
          <span class="text-xs text-on-surface-variant">{readTime}</span>
        )
      }
    </div>
    <h3
      class="mb-4 font-headline text-2xl font-bold transition-colors group-hover:text-primary"
    >
      {title}
    </h3>
    <p class="mb-6 leading-relaxed text-on-surface-variant">{description}</p>
    <div class="flex items-center gap-2 text-sm font-bold text-on-surface">
      {readTime || "Read Protocol"}
      <span class="material-symbols-outlined text-sm">north_east</span>
    </div>
  </div>
</a>
