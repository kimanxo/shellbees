---
interface Stat {
  number: string;
  label: string;
  details: string;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<article
  class="relative overflow-hidden rounded-xl border border-outline-variant/5 bg-surface-container-high p-10 md:col-span-2"
>
  <div class="relative z-10 flex flex-col gap-10 md:flex-row md:items-center">
    {
      stats.map((stat, index) => (
        <div
          class={`flex items-center gap-4 ${index < stats.length - 1 ? "border-outline-variant/20 md:border-r md:pr-10" : ""}`}
        >
          <div class="font-headline text-5xl font-extrabold text-primary">
            {stat.number}
          </div>
          <div>
            <h4 class="mb-1 text-lg font-bold">{stat.label}</h4>
            <p class="text-xs uppercase tracking-widest text-on-surface-variant">
              {stat.details}
            </p>
          </div>
        </div>
      ))
    }
  </div>
  <div class="pointer-events-none absolute bottom-0 right-0 opacity-10">
    <span
      class="material-symbols-outlined text-[200px]"
      style="font-variation-settings: 'FILL' 1">hexagon</span
    >
  </div>
</article>
