---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import NavBar from "../../components/NavBar.astro";
import LibraryCard from "../../components/LibraryCard.astro";

// ✅ KEEP THIS EXACTLY (DO NOT TOUCH)
export async function getStaticPaths() {
  const buzzes = await getCollection("buzzes");

  return buzzes.map((buzz) => ({
    params: { slug: buzz.id.replace(".md", "") },
    props: { buzz },
  }));
}

const { buzz } = Astro.props;

// ✅ derive clean slug
const cleanSlug = buzz.id.replace(".md", "");
const protocolSlug = cleanSlug.split("/")[0];

// ✅ library (for bottom section)
const libraryItems = await getCollection("buzzes");
const sortedLibrary = libraryItems.sort((a, b) => {
  const numA = parseInt(a.id.match(/\d+/)?.[0] || "0");
  const numB = parseInt(b.id.match(/\d+/)?.[0] || "0");
  return numB - numA;
});

const relatedLibrary = sortedLibrary
  .filter((b) => b.id !== buzz.id && !b.data.isLocked)
  .slice(0, 3);
---

<BaseLayout title={`${buzz.data.title} – Buzz`}>
  <div class="main-shell">
    <NavBar active="episode" />

    <main class="pt-20">
      <!-- HERO -->
      <section class="relative flex h-[614px] items-end overflow-hidden">
        <img
          src={buzz.data.image}
          alt={buzz.data.alt}
          class="absolute inset-0 h-full w-full object-cover brightness-50"
        />
        <div
          class="absolute inset-0 bg-gradient-to-t from-background via-background/20 to-transparent"
        >
        </div>

        <div
          class="relative z-10 mx-auto grid w-full max-w-7xl grid-cols-1 items-end gap-8 px-8 pb-12 md:grid-cols-12"
        >
          <div class="md:col-span-8">
            <div class="mb-4 flex items-center gap-4">
              <span
                class="rounded-full bg-surface-container-highest px-3 py-1 text-[10px] font-headline font-bold uppercase tracking-widest text-primary"
              >
                {buzz.data.label}
              </span>
              <span class="text-sm text-on-surface-variant">
                {buzz.data.publishDate}
              </span>
            </div>

            <h1
              class="mb-6 font-headline text-5xl font-bold leading-none tracking-tighter md:text-7xl"
            >
              {buzz.data.title}
            </h1>

           
          </div>
        </div>
      </section>

      <!-- CONTENT -->
      <section class="mx-auto max-w-7xl px-8 py-20">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-12">
          <div class="space-y-12 md:col-span-7">
            <div>
              <span
                class="mb-2 block font-headline text-sm font-bold uppercase tracking-[0.2em] text-primary"
              >
                Technical Briefing
              </span>

              <h2 class="mb-6 font-headline text-3xl font-bold">
                {buzz.data.title}
              </h2>

              <div
                class="space-y-6 text-lg leading-loose text-on-surface-variant"
              >
                {
                  buzz.body ? (
                    <div set:html={buzz.body} />
                  ) : (
                    <p>No content yet.</p>
                  )
                }
              </div>
            </div>
          </div>

          <!-- SIDEBAR -->
          <aside class="space-y-8 md:col-span-5">
            <div
              class="overflow-hidden rounded-2xl bg-surface-container-low p-1"
            >
              <div
                class="rounded-xl border border-outline-variant/10 bg-surface-container-high p-8"
              >
                <h3
                  class="mb-8 flex items-center gap-3 font-headline text-xl font-bold"
                >
                  <span class="material-symbols-outlined text-primary"
                    >terminal</span
                  >
                  Resources &amp; Code
                </h3>
                <p class="text-sm text-on-surface-variant">
                  Attach resources later via frontmatter.
                </p>
              </div>
            </div>
          </aside>
        </div>
      </section>

      <!-- LIBRARY -->
      <section class="bg-surface-container-low px-8 py-20">
        <div class="mx-auto max-w-7xl">
          <div class="mb-12 flex items-end justify-between">
            <div>
              <span
                class="mb-2 block font-headline text-sm font-bold uppercase tracking-[0.2em] text-primary"
              >
                Continue Exploration
              </span>
              <h2 class="font-headline text-4xl font-bold">
                Next in the Library
              </h2>
            </div>
          </div>

          <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
            {
              (() => {
                const visible = sortedLibrary
                  .filter((b) => b.id !== buzz.id && !b.data.isLocked)
                  .slice(0, 3);

                if (visible.length === 0) {
                  return (
                    <div class="col-span-1 md:col-span-3">
                      <p class="text-on-surface-variant">No items available.</p>
                    </div>
                  );
                }

                return visible.map((item) => (
                  <LibraryCard
                    label={item.data.label}
                    title={item.data.title}
                    image={item.data.image}
                    alt={item.data.alt}
                    duration={item.data.duration || "0:00"}
                    protocolSlug={protocolSlug}
                  />
                ));
              })()
            }
          </div>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
